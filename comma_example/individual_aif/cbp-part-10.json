{
    "AIF": {
        "nodes": [
            {
                "nodeID": "iss1",
                "type": "I",
                "text": "What are the causes of long covid?"
            },
            {
                "nodeID": "l_0_iss1",
                "type": "L",
                "text": "Causes of long covid"
            },
            {
                "nodeID": "ya_0_iss1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos1",
                "type": "I",
                "text": "There are likely multiple, potentially overlapping causes of long covid."
            },
            {
                "nodeID": "l_0_pos1",
                "type": "L",
                "text": "there are likely multiple, potentially overlapping, causes of long covid"
            },
            {
                "nodeID": "ya_0_pos1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos2",
                "type": "I",
                "text": "There may be multiple subtypes of long covid associated with different symptoms and underlying causes."
            },
            {
                "nodeID": "l_0_pos2",
                "type": "L",
                "text": "there may be multiple subtypes of long covid associated with different symptoms and underlying causes"
            },
            {
                "nodeID": "ya_0_pos2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg1",
                "type": "I",
                "text": "Persistent infection with the SARS-CoV-2 virus, which causes Covid-19, may be a cause."
            },
            {
                "nodeID": "l_0_arg1",
                "type": "L",
                "text": "Persistent infection with the SARS-CoV-2 virus, which causes Covid-19"
            },
            {
                "nodeID": "ya_0_arg1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg2",
                "type": "I",
                "text": "Immune system problems, including the reactivation of dormant viruses or the development of an autoimmune response, may be a cause."
            },
            {
                "nodeID": "l_0_arg2",
                "type": "L",
                "text": "Immune system problems, including the reactivation of other viruses that may be dormant in the body, or the development of an autoimmune response, where the body attacks its own systems"
            },
            {
                "nodeID": "ya_0_arg2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg3",
                "type": "I",
                "text": "Changes to the microbiota, the microorganisms that live on and in the human body, may be a cause."
            },
            {
                "nodeID": "l_0_arg3",
                "type": "L",
                "text": "Changes to the microbiota, the microorganisms that live on and in the human body"
            },
            {
                "nodeID": "ya_0_arg3",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg4",
                "type": "I",
                "text": "Problems with blood clotting and changes to endothelial cells inside blood vessels may be a cause."
            },
            {
                "nodeID": "l_0_arg4",
                "type": "L",
                "text": "Problems with blood clotting and changes to endothelial cells, which are found inside blood vessels"
            },
            {
                "nodeID": "ya_0_arg4",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg5",
                "type": "I",
                "text": "Problems with the nervous system, including the brainstem or vagus nerve, may be a cause."
            },
            {
                "nodeID": "l_0_arg5",
                "type": "L",
                "text": "Problems with the nervous system, including in the brainstem or vagus nerve, which carries signals between the brain, heart and digestive system"
            },
            {
                "nodeID": "ya_0_arg5",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "iss2",
                "type": "I",
                "text": "How many people are affected by long covid?"
            },
            {
                "nodeID": "l_0_iss2",
                "type": "L",
                "text": "How many people are affected by long covid?"
            },
            {
                "nodeID": "ya_0_iss2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos3",
                "type": "I",
                "text": "In March 2023, an estimated 1.9 million people in the UK were experiencing self-reported long covid, representing 2.9% of the population."
            },
            {
                "nodeID": "l_0_pos3",
                "type": "L",
                "text": "In March 2023, an estimated 1.9 million people in the UK were experiencing self-reported long covid, representing 2.9% of the population"
