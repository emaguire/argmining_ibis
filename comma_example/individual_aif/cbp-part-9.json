{
    "AIF": {
        "nodes": [
            {
                "nodeID": "iss1",
                "type": "I",
                "text": "Are some groups more likely to experience long covid than others?"
            },
            {
                "nodeID": "l_0_iss1",
                "type": "L",
                "text": "some groups are more likely to experience long covid than others"
            },
            {
                "nodeID": "ya_0_iss1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos1",
                "type": "I",
                "text": "The prevalence of self-reported long covid was greater among female respondents than male respondents."
            },
            {
                "nodeID": "l_0_pos1",
                "type": "L",
                "text": "the prevalence of self-reported long covid was greater among female respondents (3.3%) than male respondents (2.5%)"
            },
            {
                "nodeID": "ya_0_pos1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos2",
                "type": "I",
                "text": "Prevalence rates of long covid were higher among people aged 35 to 69 than the general population."
            },
            {
                "nodeID": "l_0_pos2",
                "type": "L",
                "text": "Prevalence rates were higher among people aged 35 to 49 (4.2%) and 50 to 69 (4.5%) than the general population (2.9%)"
            },
            {
                "nodeID": "ya_0_pos2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos3",
                "type": "I",
                "text": "Children and young people under the age of 25 were at the lowest risk of long covid."
            },
            {
                "nodeID": "l_0_pos3",
                "type": "L",
                "text": "Children and young people were least at risk, with rates in those under the age of 25 lower than in all other age groups"
            },
            {
                "nodeID": "ya_0_pos3",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos4",
                "type": "I",
                "text": "People with pre-existing health conditions that limit day-to-day activities were considerably more likely to experience long covid."
            },
            {
                "nodeID": "l_0_pos4",
                "type": "L",
                "text": "people who had a self-reported, preexisting health condition that affects their ability to carry out day-to-day activities, who were considerably more likely to experience long covid than those with a non-limiting health condition or no pre-existing conditions"
            },
            {
                "nodeID": "ya_0_pos4",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos5",
                "type": "I",
                "text": "The prevalence of self-reported long covid was higher among those living in the most deprived areas."
            },
            {
                "nodeID": "l_0_pos5",
                "type": "L",
                "text": "Prevalence of self-reported long covid was higher among those living in the most deprived areas (3.9%)"
            },
            {
                "nodeID": "ya_0_pos5",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos6",
                "type": "I",
                "text": "A higher proportion of people in the White ethnic group reported experiencing long covid than those in Black or Asian ethnic groups."
            },
            {
                "nodeID": "l_0_pos6",
                "type": "L",
                "text": "A higher proportion of people in the White ethnic group reported experiencing long covid (3.0%) than people in the Black (1.7%) or Asian (2.4%) ethnic groups"
            },
            {
                "nodeID": "ya_0_pos6",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos7",
                "type": "I",
                "text": "Prevalence rates of long covid were higher among people working in social and health care than in other employment sectors."
            },
            {
                "nodeID": "l_0_pos7",
                "type": "L",
                "text": "Prevalence rates were also higher among people working in social care (5.3%) and health care (4.4%) than in other employment sectors"
            },
            {
                "nodeID": "ya_0_pos7",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos8",
                "type": "I",
                "text": "The prevalence of long covid was highest among people living in the North East of England and Scotland."
            },
            {
                "nodeID": "l_0_pos8",
                "type": "L",
                "text": "prevalence was highest among those living in the North East of England (3.7%) and in Scotland (3.3%)"
            },
            {
                "nodeID": "ya_0_pos8",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "iss2",
                "type": "I",
                "text": "How has long covid affected healthcare services?"
            },
            {
                "nodeID": "l_0_iss2",
                "type": "L",
                "text": "How has long covid affected healthcare services?"
            },
            {
                "nodeID": "ya_0_iss2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos9",
                "type": "I",
                "text": "The impact of long covid on healthcare services centres on the cost of providing services and the effect on the NHS workforce."
            },
            {
                "nodeID": "l_0_pos9",
                "type": "L",
                "text": "Concerns about the impact of long covid on healthcare services centre on the cost of providing services for long covid patients and the impact of long covid on the NHS workforce"
            },
            {
                "nodeID": "ya_0_pos9",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg1",
                "type": "I",
                "text": "Between 5,000 and 10,000 NHS staff could be off sick with long covid."
            },
            {
                "nodeID": "l_0_arg1",
                "type": "L",
                "text": "between 5,000 and 10,000 NHS staff could be off sick with long covid"
            },
            {
                "nodeID": "ya_0_arg1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg2",
                "type": "I",
                "text": "Primary care consultations related to long covid could cost over \u00a323 million per year."
            },
            {
                "nodeID": "l_0_arg2",
                "type": "L",
                "text": "primary care consultations in relation to long covid could cost over \u00a323 million each year"
            },
            {
                "nodeID": "ya_0_arg2",
                "type": "YA",
                "text": "Default Illocuting"
            },
