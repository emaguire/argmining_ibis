{
    "AIF": {
        "nodes": [
            {
                "nodeID": "iss1",
                "type": "I",
                "text": "What are the symptoms of long covid?"
            },
            {
                "nodeID": "l_0_iss1",
                "type": "L",
                "text": "Symptoms"
            },
            {
                "nodeID": "ya_0_iss1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos1",
                "type": "I",
                "text": "People with longer-term effects after a Covid-19 infection can experience a wide range of symptoms affecting different parts of the body."
            },
            {
                "nodeID": "l_0_pos1",
                "type": "L",
                "text": "People with longer-term effects after a Covid-19 infection can experience a wide range of symptoms that can affect different parts of the body."
            },
            {
                "nodeID": "ya_0_pos1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg1",
                "type": "I",
                "text": "Symptoms include respiratory, cardiovascular, generalised, neurological, gastrointestinal, musculoskeletal, ear, nose and throat, dermatological, and psychological or psychiatric symptoms."
            },
            {
                "nodeID": "l_0_arg1",
                "type": "L",
                "text": "Respiratory symptoms, such as breathlessness or a cough\n- Cardiovascular symptoms, such as chest tightness or pain, or palpitations\n- Generalised symptoms, including fatigue, fever (a temperature over 38\u00b0C) or pain\n- Neurological symptoms, including cognitive impairment (sometimes termed \u2018brain fog\u2019), headaches, disrupted sleep, peripheral neuropathy (pins and needles or numbness in the hands or feet), dizziness, delirium, mobility impairment or visual disturbances\n- Gastrointestinal symptoms, including pain, nausea, vomiting, diarrhoea, weight loss and reduced appetite\n- Musculoskeletal symptoms, such as joint or muscle pain\n- Ear, nose and throat symptoms, such as tinnitus (hearing sounds that do not come from an outside source), earache, sore throat, the loss of taste and/or smell, nasal congestion (blocked nose)\n- Dermatological symptoms, such as skin rashes or hair loss\n- Psychological or psychiatric symptoms, such as depression, anxiety or symptoms of post-traumatic stress disorder (PTSD)."
            },
            {
                "nodeID": "ya_0_arg1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos2",
                "type": "I",
                "text": "Some symptoms of long covid are less common in children and young people."
            },
            {
                "nodeID": "l_0_pos2",
                "type": "L",
                "text": "some symptoms are less common in children and young people"
            },
            {
                "nodeID": "ya_0_pos2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg2",
                "type": "I",
                "text": "Children may be less affected by respiratory symptoms, such as shortness of breath and cough, and cardiovascular symptoms, such as palpitations or pain."
            },
            {
                "nodeID": "l_0_arg2",
                "type": "L",
                "text": "children may be less affected by respiratory symptoms (including shortness of breath and cough) and cardiovascular symptoms (including palpitations or pain)."
            },
            {
                "nodeID": "ya_0_arg2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "iss2",
                "type": "I",
                "text": "How should long covid be assessed and investigated?"
            },
            {
                "nodeID": "l_0_iss2",
                "type": "L",
                "text": "Assessment and investigations"
            },
            {
                "nodeID": "ya_0_iss2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos3",
                "type": "I",
                "text": "NICE recommends that patients are assessed using a holistic, person-centred approach."
            },
            {
                "nodeID": "l_0_pos3",
                "type": "L",
                "text": "NICE recommends that patients are assessed using a \u201cholistic, person-centred approach\u201d."
            },
            {
                "nodeID": "ya_0_pos3",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg3",
                "type": "I",
                "text": "Assessment should include a comprehensive clinical history and an examination of physical, cognitive, psychological, and psychiatric symptoms, as well as the ability to perform daily tasks."
            },
            {
                "nodeID": "l_0_arg3",
                "type": "L",
                "text": "This assessment should include taking a comprehensive clinical history (including the history of known or suspected Covid-19 infections and other health conditions) and examining the patient to assess their physical, cognitive, psychological and psychiatric symptoms, as well as their ability to carry out day-to-day tasks."
            },
            {
                "nodeID": "ya_0_arg3",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos4",
                "type": "I",
                "text": "Tests and investigations should be offered based on symptoms to rule out serious complications of Covid-19 and alternative diagnoses."
            },
            {
                "nodeID": "l_0_pos4",
                "type": "L",
                "text": "tests and investigations should be offered to patients based on their symptoms, with the aim of ruling out serious complications of Covid-19 infection and alternative diagnoses."
            },
            {
                "nodeID": "ya_0_pos4",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg4",
                "type": "I",
                "text": "Investigations may include blood tests, exercise tolerance tests, chest x-rays, or patient self-monitoring of heart rate, blood pressure, and pulse oximetry."
            },
            {
                "nodeID": "l_0_arg4",
                "type": "L",
                "text": "These might include blood tests, exercise tolerance tests or chest x-rays (for continuing respiratory symptoms), or patients\u2019 self-monitoring of heart rate, blood pressure, pulse oximetry, or ongoing symptoms."
            },
            {
                "nodeID": "ya_0_arg4",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "iss3",
                "type": "I",
                "text": "When should patients be referred to other services?"
            },
            {
                "nodeID": "l_0_iss3",
                "type": "L",
                "text": "Referral to other services"
            },
            {
                "nodeID": "ya_0_iss3",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos5",
                "type": "I",
                "text": "Clinicians should consider referring patients to an appropriate service, such as an integrated multidisciplinary assessment service."
            },
            {
                "nodeID": "l_0_pos5",
                "type": "L",
                "text": "clinicians should consider referring people to \u201can appropriate service, such as an integrated multidisciplinary assessment service\u201d."
            },
            {
                "nodeID": "ya_0_pos5",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg5",
                "type": "I",
                "text": "Referral should be considered when serious complications of Covid-19 and alternative diagnoses have been ruled out."
            },
            {
                "nodeID": "l_0_arg5",
                "type": "L",
                "text": "When serious complications of Covid-19 and alternative diagnoses have been ruled out"
            },
            {
                "nodeID": "ya_0_arg5",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg6",
                "type": "I",
                "text": "A clinician could refer a patient to an assessment service any time after four weeks have passed since the start of an acute Covid-19 infection."
            },
            {
                "nodeID": "l_0_arg6",
                "type": "L",
                "text": "A clinician could refer a patient to an assessment service at any time after four weeks have passed since the start of an acute Covid-19 infection."
            },
            {
                "nodeID": "ya_0_arg6",
                "type": "YA",
                "text": "Default Illocuting"
            },
