            {
                "nodeID": "iss1",
                "type": "I",
                "text": "Does a patient need to have had a positive Covid-19 test to be referred to another service or to receive specialist input or investigations?"
            },
            {
                "nodeID": "l_0_iss1",
                "type": "L",
                "text": "a patient does not have to have had a positive Covid-19 test to be referred to another service or to receive specialist input or investigations"
            },
            {
                "nodeID": "ya_0_iss1",
