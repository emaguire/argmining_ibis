            {
                "nodeID": "iss2",
                "type": "I",
                "text": "How should long covid be managed and rehabilitated?"
            },
            {
                "nodeID": "l_0_iss2",
                "type": "L",
                "text": "Management and rehabilitation"
            },
            {
                "nodeID": "ya_0_iss2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos2",
                "type": "I",
                "text": "NICE guidance focuses on self-management and rehabilitation for people who are affected by long covid."
            },
            {
                "nodeID": "l_0_pos2",
                "type": "L",
                "text": "NICE guidance focuses on self-management and rehabilitation for people who are affected by the condition"
            },
            {
                "nodeID": "ya_0_pos2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg1",
                "type": "I",
                "text": "There are currently no known effective treatments that can cure long covid."
            },
            {
                "nodeID": "l_0_arg1",
                "type": "L",
                "text": "There are currently no known effective treatments that can cure long covid"
            },
            {
                "nodeID": "ya_0_arg1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "iss3",
                "type": "I",
                "text": "Are there adequate healthcare services available for people with long covid?"
            },
            {
                "nodeID": "l_0_iss3",
                "type": "L",
                "text": "availability of healthcare services"
            },
            {
                "nodeID": "ya_0_iss3",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos3",
                "type": "I",
                "text": "Some patients have been unable to access appropriate help for long covid."
            },
            {
                "nodeID": "l_0_pos3",
                "type": "L",
                "text": "some patients had been unable to access appropriate help"
            },
            {
                "nodeID": "ya_0_pos3",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos4",
                "type": "I",
                "text": "The UK Government has invested \u00a3314 million and established over 100 specialised services to provide care for people with long covid."
            },
            {
                "nodeID": "l_0_pos4",
                "type": "L",
                "text": "the UK Government states it has invested \u00a3314 million to provide care for people with long covid, and has established over 100 specialised services"
            },
            {
                "nodeID": "ya_0_pos4",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "iss4",
                "type": "I",
                "text": "Should NHS England publish a plan to deal with long covid?"
            },
            {
                "nodeID": "l_0_iss4",
                "type": "L",
                "text": "NHS England should publish a plan to deal with long covid"
            },
            {
                "nodeID": "ya_0_iss4",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos5",
                "type": "I",
                "text": "NHS England will work with stakeholders to develop and publish a new Long COVID Plan for 2022 to 2023."
            },
            {
                "nodeID": "l_0_pos5",
                "type": "L",
                "text": "NHS England will work with stakeholders, including patient groups, to develop and publish a new Long COVID Plan for 2022 to 2023"
            },
            {
                "nodeID": "ya_0_pos5",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg2",
                "type": "I",
