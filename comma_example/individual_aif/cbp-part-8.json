{
    "AIF": {
        "nodes": [
            {
                "nodeID": "iss1",
                "type": "I",
                "text": "What is the impact of long covid on healthcare services?"
            },
            {
                "nodeID": "l_0_iss1",
                "type": "L",
                "text": "the impact of long covid on healthcare services"
            },
            {
                "nodeID": "ya_0_iss1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos1",
                "type": "I",
                "text": "The impact of long covid on healthcare services centres on the cost of providing services for patients and the effect on the NHS workforce."
            },
            {
                "nodeID": "l_0_pos1",
                "type": "L",
                "text": "Concerns about the impact of long covid on healthcare services centre on the cost of providing services for long covid patients and the impact of long covid on the NHS workforce"
            },
            {
                "nodeID": "ya_0_pos1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg1",
                "type": "I",
                "text": "The British Medical Association has called for financial support and improved services for healthcare staff affected by long covid to address the impact on the workforce."
            },
            {
                "nodeID": "l_0_arg1",
                "type": "L",
                "text": "The British Medical Association, the trade union for doctors, has called for a range of measures, including financial support and improved services for doctors and healthcare staff affected by long covid"
            },
            {
                "nodeID": "ya_0_arg1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "iss2",
                "type": "I",
                "text": "Is long covid a disability?"
            },
            {
                "nodeID": "l_0_iss2",
                "type": "L",
                "text": "Whether long covid is a disability"
            },
            {
                "nodeID": "ya_0_iss2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos2",
                "type": "I",
                "text": "Long covid has had a widespread impact on the workforce."
            },
            {
                "nodeID": "l_0_pos2",
                "type": "L",
                "text": "the widespread impact that long covid has had on the workforce"
            },
            {
                "nodeID": "ya_0_pos2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg2",
                "type": "I",
                "text": "The Society of Occupational Medicine suggests that organisations should review absence management and flexible working practices to support employees affected by long covid."
            },
            {
                "nodeID": "l_0_arg2",
                "type": "L",
                "text": "The Society of Occupational Medicine... called for organisations to review their absence management and flexible working practices to help support employees"
            },
            {
                "nodeID": "ya_0_arg2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "iss3",
                "type": "I",
                "text": "Does long covid affect children's school attendance?"
            },
            {
                "nodeID": "l_0_iss3",
                "type": "L",
                "text": "long covid can affect children\u2019s school attendance"
            },
            {
                "nodeID": "ya_0_iss3",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos3",
                "type": "I",
                "text": "Children affected by long covid may require additional support to access full-time education."
            },
            {
                "nodeID": "l_0_pos3",
                "type": "L",
                "text": "affected children may need additional support to access full-time education"
            },
            {
                "nodeID": "ya_0_pos3",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg3",
                "type": "I",
                "text": "There are concerns regarding increased absence from school since the relaxation of pandemic restrictions."
            },
            {
                "nodeID": "l_0_arg3",
                "type": "L",
                "text": "there have been concerns about increased absence from school"
            },
            {
                "nodeID": "ya_0_arg3",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "iss4",
                "type": "I",
                "text": "How is long covid diagnosed?"
            },
            {
                "nodeID": "l_0_iss4",
                "type": "L",
                "text": "How is long covid diagnosed?"
            },
            {
                "nodeID": "ya_0_iss4",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos4",
                "type": "I",
                "text": "NICE provides specific case definitions to help clinicians identify and diagnose the longer-term effects of Covid-19."
            },
            {
                "nodeID": "l_0_pos4",
                "type": "L",
                "text": "The NICE guidance includes the following case definitions to help clinicians to identify and diagnose longer-term effects of Covid-19"
            },
            {
                "nodeID": "ya_0_pos4",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg4",
                "type": "I",
                "text": "Post-Covid-19 syndrome is diagnosed when symptoms continue for more than 12 weeks and cannot be explained by another diagnosis."
            },
            {
                "nodeID": "l_0_arg4",
                "type": "L",
                "text": "Post-Covid-19 syndrome: signs and symptoms that develop during or after an infection consistent with Covid-19, that continue for more than 12 weeks, and are not explained by an alternative diagnosis"
            },
            {
                "nodeID": "ya_0_arg4",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos5",
                "type": "I",
                "text": "The World Health Organization has published its own clinical case definition for post-Covid-19 condition."
            },
            {
                "nodeID": "l_0_pos5",
                "type": "L",
                "text": "the World Health Organization (WHO) published a clinical case definition of post-Covid-19 condition"
            },
            {
                "nodeID": "ya_0_pos5",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg5",
                "type": "I",
                "text": "The WHO definition is similar to the definition adopted by NICE for post-Covid-19 syndrome."
            },
            {
                "nodeID": "l_0_arg5",
                "type": "L",
                "text": "The definition proposed by WHO is similar to the definition adopted by NICE for post-Covid-19 syndrome"
            },
            {
                "nodeID": "ya_0_arg5",
                "type": "YA",
                "text": "Default Illocuting"
            },
