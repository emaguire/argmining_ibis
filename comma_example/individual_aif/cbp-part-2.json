{
    "AIF": {
        "nodes": [
            {
                "nodeID": "iss1",
                "type": "I",
                "text": "What are the causes of long covid and what are the best treatments?"
            },
            {
                "nodeID": "l_0_iss1",
                "type": "L",
                "text": "There is no consensus on the causes of long covid or on the best treatments."
            },
            {
                "nodeID": "ya_0_iss1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos1",
                "type": "I",
                "text": "Persistent symptoms of long covid are associated with female sex, higher deprivation, pre-existing health conditions, more severe acute Covid-19 symptoms and infection with the original \u201cWild-type\u201d SARS-Cov-2 variant."
            },
            {
                "nodeID": "l_0_pos1",
                "type": "L",
                "text": "persistent symptoms were associated with female sex, higher deprivation, pre-existing health conditions, more severe acute Covid-19 symptoms and being infected with the original \u201cWild-type\u201d SARS-Cov-2 variant."
            },
            {
                "nodeID": "ya_0_pos1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos2",
                "type": "I",
                "text": "Prolonged symptoms after Covid-19 are associated with female sex, white ethnicity, poor pre-pandemic health, obesity and asthma."
            },
            {
                "nodeID": "l_0_pos2",
                "type": "L",
                "text": "prolonged symptoms after Covid-19 were associated with female sex, white ethnicity, poor pre-pandemic health, obesity and asthma."
            },
            {
                "nodeID": "ya_0_pos2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos3",
                "type": "I",
                "text": "Long covid is associated with female sex, non-white ethnicity, obesity and pre-existing medical conditions, including anxiety and type 2 diabetes."
            },
            {
                "nodeID": "l_0_pos3",
                "type": "L",
                "text": "long covid was associated with female sex, non-white ethnicity, obesity and pre-existing medical conditions, including anxiety and type 2 diabetes."
            },
            {
                "nodeID": "ya_0_pos3",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "pos4",
                "type": "I",
                "text": "Multidisciplinary care and the involvement of people with lived experience are important in the design and evaluation of long covid services."
            },
            {
                "nodeID": "l_0_pos4",
                "type": "L",
                "text": "highlighting the importance of multidisciplinary care and involving people with lived experience in the design and evaluation of long covid services."
            },
            {
                "nodeID": "ya_0_pos4",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg1",
                "type": "I",
                "text": "The REACT Long COVID study uses surveys and interviews to understand experiences and why some people are affected by longer-term symptoms."
            },
            {
                "nodeID": "l_0_arg1",
                "type": "L",
                "text": "REACT Long COVID: this study is gathering data using surveys and interviews to help researchers understand experiences of long covid and why some people are affected by longer-term symptoms."
            },
            {
                "nodeID": "ya_0_arg1",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg2",
                "type": "I",
                "text": "The Convalescence study uses various research methods to explore definitions, risk factors, and consequences of long covid."
            },
            {
                "nodeID": "l_0_arg2",
                "type": "L",
                "text": "Convalescence: this study is using a variety of research methods to explore definitions of long covid, risk factors and consequences of the condition"
            },
            {
                "nodeID": "ya_0_arg2",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg3",
                "type": "I",
                "text": "The STIMULATE-ICP study assesses integrated care pathways and tests the effectiveness of common medicines for treating long covid."
            },
            {
                "nodeID": "l_0_arg3",
                "type": "L",
                "text": "STIMULATE-ICP: this study is using a range of research methods to assess integrated care pathways for patients with long covid and to test common medicines to see if they are effective in treating long covid."
            },
            {
                "nodeID": "ya_0_arg3",
                "type": "YA",
                "text": "Default Illocuting"
            },
            {
                "nodeID": "arg4",
                "type": "I",
                "text": "The LOCOMOTION study examined existing models of care to develop a gold standard for long covid care in different settings."
            },
            {
                "nodeID": "l_0_arg4",
                "type": "L",
                "text": "LOCOMOTION: this study used a range of research methods to examine existing models of care for patients with long covid to develop a \u2018gold standard\u2019 for care in different settings."
            },
            {
                "nodeID": "ya_0_arg4",
                "type": "YA",
                "text": "Default Illocuting"
            },
